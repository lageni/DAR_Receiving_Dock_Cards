# CodePuppyDAR - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Inventory API Credentials (REQUIRED)
INVENTORY_JWT_TOKEN=your-jwt-token-here
INVENTORY_USER_ID=your-user-id-here
INVENTORY_API_URL=https://inventory-viewer.prod.walmart.net
INVENTORY_DEFAULT_NODE=6068
INVENTORY_COUNTRY_CODE=US

# MDM Item API Credentials (REQUIRED)
MDM_API_KEY=your-mdm-api-key-here
MDM_FACILITY_NUM=6068
MDM_FACILITY_COUNTRY_CODE=US
MDM_WMT_USERID=mdm-ui

# Informix Database Credentials (REQUIRED)
INFORMIX_HOST=your-informix-host
INFORMIX_SERVER=your-informix-server
INFORMIX_PORT=23301
INFORMIX_USER=your-username
INFORMIX_PASSWORD=your-password
INFORMIX_DATABASE=dc_sys_common

# Google Cloud BigQuery (Optional - for sync_bigquery.py)
GCS_PROJECT_ID=
GCS_DATASET_ID=
GCS_TABLE_ID=

# Database Configuration (REQUIRED)
# DATABASE_PATH can be:
#   - Relative path: "read_rates.db" (will be relative to app directory)
#   - Absolute path: "L:\\Engineering\\DAR Docktag Cards\\read_rates.db" (Windows)
#   - Leave blank to default to "read_rates.db" in app directory
DATABASE_PATH=L:\\Engineering\\DAR Docktag Cards\\read_rates.db
DATABASE_ADMIN_PASSWORD=your-admin-password

# Walmart Scheduler Auto-Login (Optional)
WALMART_USERNAME=your-username
WALMART_PASSWORD=your-password

# SSO Automation (Optional)
ID=your-id-here
username=your-email@wmsc.wal-mart.com
SCHEDULER_JWT_TOKEN=your-scheduler-jwt-token
