            grid-template-columns: 3.5in 1fr;
            gap: 30px;
            min-height: 100%;
        }}
        .product-section {{
            display: flex;
            flex-direction: column;
            gap: 15px;
        }}
        .card-image {{
            width: 100%;
            height: 4.5in;
            overflow: hidden;
            border-radius: 8px;
            border: 2px solid #0071ce;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f9f9f9;
        }}
        .card-image img {{
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }}
        .product-name {{
            font-size: 18px;
            font-weight: bold;
            color: #0071ce;
            line-height: 1.3;
        }}
        .info-section {{
            border-top: 1px solid #ddd;
            padding-top: 12px;
        }}
        .info-row {{
            display: flex;
            flex-direction: column;
            margin-bottom: 8px;
            font-size: 11px;
        }}
        .info-label {{
            font-weight: 600;
            color: #333;
            margin-bottom: 2px;
        }}
        .info-value {{
            color: #666;
            word-break: break-word;
        }}
        .status-badge {{
            display: inline-block;
            padding: 6px 12px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 12px;
            margin-top: 8px;
            width: fit-content;
        }}
        .status-in-stock {{
            background: #d4edda;
            color: #155724;
        }}
        .status-unknown {{
            background: #fff3cd;
            color: #856404;
        }}
        .right-column {{
            display: flex;
            flex-direction: column;
            gap: 20px;
        }}
        .acl-section {{
            display: flex;
            flex-direction: column;
            gap: 12px;
        }}
        .acl-title {{
            font-size: 16px;
            font-weight: bold;
            color: #0071ce;
        }}
        .acl-metrics {{
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }}
        .metric-card {{
            padding: 12px;
            border-radius: 4px;
            text-align: center;
        }}
        .metric-label {{
            font-weight: 600;
            font-size: 10px;
            margin-bottom: 4px;
        }}
        .metric-value {{
            font-size: 20px;
            font-weight: bold;
        }}
        .metric-perf {{
            background: #fffacd;
            border: 1px solid #daa520;
            color: #8b7500;
        }}
        .metric-trend {{
            background: #f0e6ff;
            border: 1px solid #9370db;
            color: #3d1a7f;
        }}
        .trend-chart {{
            margin-top: 8px;
            height: 1.2in;
            border: 1px solid #ddd;
            border-radius: 4px;
            background: #fafafa;
            padding: 8px;
        }}
        @media print {{
            body {{
                background: white;
                padding: 0;
            }}
            .print-container {{
                max-width: 100%;
                box-shadow: none;
                margin: 0;
            }}
            .no-print {{
                display: none;
            }}
        }}
        .no-print {{
            text-align: center;
            margin-top: 20px;
        }}
        .no-print button {{
            padding: 10px 24px;
            background: #0071ce;
            color: white;
            border: none;
            border-radius: 4px;
            font-weight: 600;
            cursor: pointer;
            margin: 0 8px;
        }}
        .no-print button:hover {{
            background: #005a9c;
        }}
    </style>
</head>
<body>
    <div class="print-container">
        <div class="product-section">
            {image_section}
            <div class="product-name">{item_name}</div>
            <div class="info-section">
                <div class="info-row">
                    <div class="info-label">Item ID:</div>
                    <div class="info-value">{item_id}</div>
                </div>
                {f'<div class="info-row"><div class="info-label">GTIN:</div><div class="info-value">{gtin}</div></div>' if gtin else ''}
                {f'<div class="info-row"><div class="info-label">Product ID:</div><div class="info-value">{product_id}</div></div>' if product_id else ''}
                {f'<div class="info-row"><div class="info-label">Supplier:</div><div class="info-value">{supplier_dept}</div></div>' if supplier_dept else ''}
            </div>
            <div class="info-section">
                <div class="info-label">Status</div>
                <div class="status-badge {'status-in-stock' if 'In Stock' in inventory_status else 'status-unknown'}">{inventory_status}</div>
            </div>
        </div>
        <div class="right-column">
            <div class="acl-section">
                <div class="acl-title">ACL Performance %</div>
                <div id="acl-content">Loading performance data...</div>
            </div>
        </div>
    </div>
    <div class="no-print">
        <button onclick="window.print()">Print Card</button>
        <button onclick="window.history.back()">Back</button>
    </div>
</body>
</html>"""


def sanitize_for_pdf(text: str) -> str:
    """Remove Unicode chars that Helvetica font can't render."""
    if not text:
        return ""
    # Replace smart quotes and common Unicode chars with ASCII equivalents
    replacements = {
        "\u201c": '"',  # left double quote
        "\u201d": '"',  # right double quote
        "\u2018": "'",  # left single quote
        "\u2019": "'",  # right single quote
        "\u2013": "-",   # en dash
        "\u2014": "-",   # em dash
        "\u2022": "*",   # bullet
        "\u00a9": "(c)", # copyright
        "\u00ae": "(R)", # registered
        "\u2122": "(TM)", # trademark
    }
    result = str(text)
    for unicode_char, ascii_equiv in replacements.items():
        result = result.replace(unicode_char, ascii_equiv)
    # Strip any remaining non-ASCII characters
    return result.encode('ascii', errors='ignore').decode('ascii')


def generate_pdf(item_data: dict) -> bytes:
    """Generate a clean landscape PDF card with product information."""
    pdf = FPDF(orientation='L', unit='in', format='Letter')  # 11" x 8.5" landscape
    pdf.add_page()
    pdf.set_margins(0.4, 0.4, 0.4)
    
    item_name = sanitize_for_pdf(item_data.get("item_name", "Unknown Item"))
    image_url = item_data.get("image_url", "")
    gtin = sanitize_for_pdf(item_data.get("gtin", ""))
    product_id = sanitize_for_pdf(item_data.get("product_id", ""))
    supplier_dept = sanitize_for_pdf(item_data.get("supplier_dept", ""))
    inventory_status = sanitize_for_pdf(item_data.get("inventory_status", "Unknown"))
    # Keep original item_id for dictionary lookup, use sanitized version for PDF display
    item_id_orig = item_data.get("item_id", "")
    item_id = sanitize_for_pdf(item_id_orig)
    
    # LEFT COLUMN: Product Image and Details
    img_x = 0.4
    img_y = 0.4
    img_width = 3.2
    img_height = 4.0
    
    # Draw image border
    pdf.set_draw_color(0, 83, 226)
    pdf.set_line_width(0.02)
    pdf.rect(img_x, img_y, img_width, img_height)
    
    if image_url:
        try:
            img_response = httpx.get(image_url, timeout=5)
            img_bytes = BytesIO(img_response.content)
            temp_img = "/tmp/product.jpg"
            with open(temp_img, 'wb') as f:
                f.write(img_bytes.getvalue())
            # Center image in the box
            pdf.image(temp_img, x=img_x+0.05, y=img_y+0.05, w=img_width-0.1, h=img_height-0.1)
        except:
            pass
    
    # Product name below image (left column)
    pdf.set_xy(img_x, img_y + img_height + 0.15)
    pdf.set_font("Helvetica", "B", 12)
    pdf.set_text_color(0, 83, 226)
    pdf.multi_cell(img_width, 0.22, item_name, align='C')
    
    current_y_left = pdf.get_y() + 0.05
    
    # Product details (left column) - compact
    pdf.set_xy(img_x, current_y_left)
    pdf.set_font("Helvetica", "", 8)
    pdf.set_text_color(80, 80, 80)
    
    details = f"Item: {item_id}"
    if gtin:
        details += f" | GTIN: {gtin}"
    if product_id:
        details += f" | PID: {product_id}"
    if supplier_dept:
        details += f" | Supplier: {supplier_dept}"
    
    pdf.multi_cell(img_width, 0.18, details, align='C')
    
    # RIGHT COLUMN: ACL Performance Section
    right_x = 3.8
    right_y = 0.4
    right_width = 6.8
    
    # ACL Title
    pdf.set_xy(right_x, right_y)
    pdf.set_font("Helvetica", "B", 14)
    pdf.set_text_color(0, 83, 226)
    pdf.cell(right_width, 0.3, "ACL Performance %", align='L')
    
    current_y = right_y + 0.35
    
    # Get read rates for this item
    rates = load_read_rates()
    item_rates = rates.get(str(item_id_orig), [])
    
    if item_rates:
        # Calculate metrics
        avg_perf = get_avg_performance(item_rates)
        trend_status = get_trend_status(item_rates)
        color = get_color_for_performance(avg_perf)
        
        # Metrics boxes in a grid (2 columns)
        box_width = (right_width - 0.2) / 2
        box_height = 0.6
        
        # AVG PERFORMANCE box
        box_x1 = right_x
        box_y1 = current_y
        pdf.set_fill_color(255, 250, 220)  # Light yellow
        pdf.set_draw_color(218, 165, 32)  # Goldenrod border
        pdf.set_line_width(0.015)
        pdf.rect(box_x1, box_y1, box_width, box_height, style='FD')
        
        # Label
        pdf.set_xy(box_x1 + 0.05, box_y1 + 0.05)
        pdf.set_font("Helvetica", "B", 7)
        pdf.set_text_color(180, 140, 0)
        pdf.cell(box_width - 0.1, 0.12, "PERFORMANCE", align='C')
        
        # Value
        pdf.set_xy(box_x1 + 0.05, box_y1 + 0.23)
        pdf.set_font("Helvetica", "B", 18)
        # Convert hex color to RGB
        if color == "#dc2626":
            pdf.set_text_color(220, 38, 38)
        elif color == "#f59e0b":
            pdf.set_text_color(245, 158, 11)
        elif color == "#eab308":
            pdf.set_text_color(234, 179, 8)
        else:  # green
            pdf.set_text_color(22, 163, 74)
        pdf.cell(box_width - 0.1, 0.25, f"{avg_perf:.1f}%", align='C')
        
        # TREND box
        box_x2 = right_x + box_width + 0.2
        box_y2 = current_y
        pdf.set_fill_color(240, 230, 255)  # Light purple
        pdf.set_draw_color(147, 112, 219)  # Medium purple border
        pdf.set_line_width(0.015)
        pdf.rect(box_x2, box_y2, box_width, box_height, style='FD')
        
        # Label
        pdf.set_xy(box_x2 + 0.05, box_y2 + 0.05)
        pdf.set_font("Helvetica", "B", 7)
        pdf.set_text_color(140, 100, 180)
        pdf.cell(box_width - 0.1, 0.12, "TREND", align='C')
        
        # Value
        pdf.set_xy(box_x2 + 0.05, box_y2 + 0.23)
        pdf.set_font("Helvetica", "B", 14)
        pdf.set_text_color(60, 20, 140)
        pdf.cell(box_width - 0.1, 0.25, trend_status, align='C')
        
        current_y += box_height + 0.2
        
        # Draw trend visualization (compact chart)
        if len(item_rates) > 1:
            # Chart dimensions
            chart_x = right_x
            chart_y = current_y
            chart_width = right_width
            chart_height = 1.5
            
            # Draw border
            pdf.set_draw_color(200, 200, 200)
            pdf.set_line_width(0.01)
            pdf.rect(chart_x, chart_y, chart_width, chart_height)
            
            # Draw axes
            ax_left = chart_x + 0.35
            ax_bottom = chart_y + chart_height - 0.25
            ax_height = chart_height - 0.35
            ax_width = chart_width - 0.5
            
            pdf.set_draw_color(100, 100, 100)
            pdf.set_line_width(0.015)
            pdf.line(ax_left, ax_bottom, ax_left, chart_y + 0.15)  # Y-axis
            pdf.line(ax_left, ax_bottom, ax_left + ax_width, ax_bottom)  # X-axis
            
            # Draw grid lines
            pdf.set_draw_color(220, 220, 220)
            pdf.set_line_width(0.008)
            for pct in [0, 25, 50, 75, 100]:
                y_pos = ax_bottom - (pct / 100.0) * ax_height
                pdf.line(ax_left, y_pos, ax_left + ax_width, y_pos)
            
            # Plot data points and connect with line
            pdf.set_draw_color(0, 83, 226)  # Walmart Blue
            pdf.set_line_width(0.02)
            
            points = []
            for i, rate in enumerate(item_rates):
                x = ax_left + (i / max(len(item_rates) - 1, 1)) * ax_width
                y = ax_bottom - (rate['null_pct'] / 100.0) * ax_height
                points.append((x, y))
            
            # Draw line connecting points
            for i in range(len(points) - 1):
                x1, y1 = points[i]
                x2, y2 = points[i + 1]
                pdf.line(x1, y1, x2, y2)
            
            # Draw points
            pdf.set_fill_color(0, 83, 226)
            for x, y in points:
                pdf.circle(x, y, 0.04, style='F')
    else:
        # No ACL data
        pdf.set_xy(right_x, current_y)
        pdf.set_font("Helvetica", "", 10)
        pdf.set_text_color(150, 150, 150)
        pdf.cell(right_width, 0.3, "No ACL performance data available", align='L')
    
    # Convert to bytes
    result = pdf.output(dest='S')
    return bytes(result) if isinstance(result, bytearray) else result


if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
